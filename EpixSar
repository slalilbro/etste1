    end)
    local ok2,AnimalsData = pcall(function()
        return require(ReplicatedStorage:WaitForChild("Datas"):WaitForChild("Animals"))
    end)
    local ok3,AnimalsShared = pcall(function()
        return require(ReplicatedStorage:WaitForChild("Shared"):WaitForChild("Animals"))
    end)
    local ok4,NumberUtils = pcall(function()
        return require(ReplicatedStorage:WaitForChild("Utils"):WaitForChild("NumberUtils"))
    end)
    if not (ok1 and ok2 and ok3 and ok4) then return end

    local function scanPlot(plot)
        local ok,ch = pcall(function() return Sync:Get(plot.Name) end)
        if not ok or not ch then return end
        local al = ch:Get("AnimalList")
        if not al then return end
        local owner = ch:Get("Owner")
        local ownerName = (typeof(owner)=="Instance" and owner:IsA("Player") and owner.Name) or (type(owner)=="table" and owner.Name) or "?"
        for i=#AllAnimalsCache,1,-1 do
            if AllAnimalsCache[i].plot==plot.Name then table.remove(AllAnimalsCache,i) end
        end
        for slot,ad in pairs(al) do
            if type(ad)=="table" then
                local info = AnimalsData[ad.Index]
                if info then
                    local gv = AnimalsShared:GetGeneration(ad.Index,ad.Mutation,ad.Traits,nil)
                    table.insert(AllAnimalsCache,{
                        name      = info.DisplayName or ad.Index,
                        index     = ad.Index,
                        genValue  = gv,
                        genText   = "$"..NumberUtils:ToString(gv).."/s",
                        mutation  = ad.Mutation or "None",
                        owner     = ownerName,
                        plot      = plot.Name,
                        slot      = tostring(slot),
                        uid       = plot.Name.."_"..tostring(slot),
                    })
                end
            end
        end
        table.sort(AllAnimalsCache,function(a,b) return a.genValue>b.genValue end)
    end

    local plots = Workspace:WaitForChild("Plots",8)
    if not plots then return end
    for _,p in ipairs(plots:GetChildren()) do task.spawn(scanPlot,p) end
    plots.ChildAdded:Connect(function(p) task.wait(0.5); task.spawn(scanPlot,p) end)
    plots.ChildRemoved:Connect(function(p)
        for i=#AllAnimalsCache,1,-1 do
            if AllAnimalsCache[i].plot==p.Name then table.remove(AllAnimalsCache,i) end
        end
    end)
    while true do
        task.wait(5)
        for _,p in ipairs(plots:GetChildren()) do task.spawn(scanPlot,p) end
    end
end)

