local function safeKey(name, fallback)
    if type(name)~="string" or name=="" then return fallback end
    local ok,kc = pcall(function() return Enum.KeyCode[name] end)
    return (ok and kc) or fallback
end

UserInputService.InputBegan:Connect(function(input, processed)
    if processed then return end
    
    if input.KeyCode == safeKey(Config.TpKey, Enum.KeyCode.T) then
        -- ATIVA RAGDOLL PRIMEIRO
        activateSelfRagdoll()
        task.wait(0.10)  -- ALTERADO DE 0.15 PARA 0.10
        -- DEPOIS EXECUTA O TP
        tpToBestBrainrot()
    end
    
    if input.KeyCode == safeKey(Config.CloneKey, Enum.KeyCode.V) then
        instantClone()
    end
end)

