        if Config.AutoTPPriority then
            for _,pName in ipairs(PRIORITY_LIST) do
                local lower = pName:lower()
                for _,a in ipairs(AllAnimalsCache) do
                    if a.name and a.name:lower()==lower and not isMyBaseAnimal(a) then
                        targetPetData = a; break
                    end
                end
                if targetPetData then break end
            end
        end
        if not targetPetData then
            for _,a in ipairs(AllAnimalsCache) do
                if not isMyBaseAnimal(a) then targetPetData=a; break end
            end
        end
    end

    if not targetPetData then
        notify("TP","Nenhum alvo encontrado!")
        return
    end

    local char = LocalPlayer.Character
    local hrp  = char and char:FindFirstChild("HumanoidRootPart")
    local hum  = char and char:FindFirstChild("Humanoid")
    if not hrp or not hum or hum.Health<=0 then return end

    isTpMoving = true
    notify("TP","→ "..tostring(targetPetData.name))

    local ok, err = pcall(function()
        local targetPart = findAdornee(targetPetData)
        if not targetPart then error("Adornee não encontrado") end

        local exactPos  = targetPart.Position
        local carpetName = Config.Tool
        local carpet = LocalPlayer.Backpack:FindFirstChild(carpetName) or char:FindFirstChild(carpetName)
        if carpet then hum:EquipTool(carpet) end
        task.wait(0.01)

        local isSecondFloor = exactPos.Y > 10
        local plotIndex     = getClosestBaseIdx(exactPos)
        local targetBasePos = isSecondFloor and BASES_HIGH[plotIndex] or BASES_LOW[plotIndex]
        local minHeight     = 50
        local targetHeight  = math.max(targetBasePos.Y, minHeight)

        local t0 = tick()
        while hrp.Position.Y < targetHeight and (tick()-t0) < 2 do
            hrp.AssemblyLinearVelocity = Vector3.new(hrp.AssemblyLinearVelocity.X, 280, hrp.AssemblyLinearVelocity.Z)
            RunService.Heartbeat:Wait()
        end

        for _=1,8 do
            hrp.AssemblyLinearVelocity = Vector3.new(hrp.AssemblyLinearVelocity.X,0,hrp.AssemblyLinearVelocity.Z)
            if (hrp.Position-targetBasePos).Magnitude > 3 then
                hrp.CFrame = CFrame.new(targetBasePos)
                task.wait(0.03)
            end
        end

        if not isSecondFloor then
            local bestSpot = CLONE_POSITIONS_FLOOR[1]
            local minDst = math.huge
            for _,v in ipairs(CLONE_POSITIONS_FLOOR) do
                local d = (targetPart.Position-v).Magnitude
                if d < minDst then minDst=d; bestSpot=v end
            end
            for _=1,4 do
                if (hrp.Position-bestSpot).Magnitude > 3 then
                    hrp.CFrame = CFrame.new(bestSpot)
                    task.wait(0.03)
                end
            end
        end

        local bestFace = FACE_TARGETS[1]
        local minFace  = math.huge
        for _,v in ipairs(FACE_TARGETS) do
            local d=(hrp.Position-v).Magnitude
            if d<minFace then minFace=d; bestFace=v end
        end
        task.wait(0.01)
        hrp.CFrame = CFrame.lookAt(hrp.Position, Vector3.new(bestFace.X,hrp.Position.Y,bestFace.Z))

        local plotUnlocked = true
        pcall(function()
            local plots = Workspace:FindFirstChild("Plots")
            local tp2 = plots and plots:FindFirstChild(targetPetData.plot)
            if tp2 then
                local unlockFolder = tp2:FindFirstChild("Unlock")
                if unlockFolder then
                    for _,item in ipairs(unlockFolder:GetChildren()) do
                        for _,desc in ipairs(item:GetDescendants()) do
                            if desc:IsA("ProximityPrompt") and desc.Enabled then
                                plotUnlocked = false; break
                            end
                        end
                        if not plotUnlocked then break end
                    end
                end
            end
        end)

        if isSecondFloor or not plotUnlocked then
            walkForward(0.25)
            task.wait(0.35)
            instantClone()
            while isCloning do task.wait() end
            task.wait(0.20)
        end

        task.wait(0.10)
        if carpet then hum:EquipTool(carpet) end

        local vertDiff = targetPart.Position.Y - hrp.Position.Y
        if vertDiff > 2 then
            local airPos = Vector3.new(targetPart.Position.X, targetPart.Position.Y-8, targetPart.Position.Z)
            local plat = Instance.new("Part")
            plat.Name = "XiTempPlatform"
            plat.Size = Vector3.new(3,1,3)
            plat.Position = airPos - Vector3.new(0,5,0)
            plat.Color = Color3.new(1,0,0)
            plat.Material = Enum.Material.Neon
            plat.Anchored = true; plat.CanCollide = true
            plat.Transparency = 0.3; plat.Parent = Workspace
            RunService.Heartbeat:Wait()
            for _=1,10 do
                if LocalPlayer:GetAttribute("Stealing") then break end
                hrp.AssemblyLinearVelocity = Vector3.new(hrp.AssemblyLinearVelocity.X,0,hrp.AssemblyLinearVelocity.Z)
                hrp.CFrame = CFrame.new(airPos)
                task.wait(0.05)
            end
            task.delay(20, function() pcall(function() plat:Destroy() end) end)
        else
            for _=1,10 do
                if LocalPlayer:GetAttribute("Stealing") then break end
                hrp.AssemblyLinearVelocity = Vector3.new(hrp.AssemblyLinearVelocity.X,0,hrp.AssemblyLinearVelocity.Z)
                if (hrp.Position-targetPart.Position).Magnitude > 3 then
                    hrp.CFrame = CFrame.new(targetPart.Position)
                    task.wait(0.05)
                end
                task.wait(0.05)
            end
        end
    end)

    isTpMoving = false
    if not ok then notify("TP","Erro: "..tostring(err):sub(1,50)) end
end

local function tpToBestBrainrot()
    local best = nil
    for _,pName in ipairs(PRIORITY_LIST) do
        local lower = pName:lower()
        for _,a in ipairs(AllAnimalsCache) do
            if a.name and a.name:lower()==lower and not isMyBaseAnimal(a) then
                best=a; break
            end
        end
        if best then break end
    end
    if not best then
        for _,a in ipairs(AllAnimalsCache) do
            if not isMyBaseAnimal(a) then best=a; break end
        end
    end
    if best then
        task.spawn(runAutoSnipe, best)
    else
        notify("TP","Nenhum brainrot encontrado!")
    end
end

